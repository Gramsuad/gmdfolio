<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Samson Adigun | Systems, Software and Security</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Sora:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --ink: #09090E;
  --ink2: #13141C;
  --ink3: #1C1E2A;
  --ink4: #232636;
  --cream: #EDEAE2;
  --amber: #E8963A;
  --amber-soft: #F4A84A;
  --amber-glow: rgba(232,150,58,0.10);
  --amber-border: rgba(232,150,58,0.22);
  --green: #22C55E;
  --text: #C8C4BC;
  --text-muted: #6B6860;
  --text-faint: #3D3C3A;
  --border: rgba(255,255,255,0.06);
  --border-light: rgba(255,255,255,0.10);
  --r: 10px;
  --rl: 16px;
  --rx: 22px;
}

html { scroll-behavior: smooth; }
body {
  font-family: 'Outfit', sans-serif;
  background: var(--ink);
  color: var(--text);
  line-height: 1.6;
  font-size: 15px;
  -webkit-font-smoothing: antialiased;
}

/* NAV */
nav {
  position: sticky; top: 0; z-index: 200;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 48px; height: 60px;
  background: rgba(9,9,14,0.88);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}
.nav-brand {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: 'Sora', sans-serif;
  font-weight: 700; font-size: 16px;
  color: var(--cream); letter-spacing: -0.4px;
  min-width: 0;
}
.nav-logo {
  width: 54px; height: 36px; max-height: 36px;
  object-fit: contain; display: block; flex: 0 0 auto;
  filter: drop-shadow(0 5px 10px rgba(0,0,0,0.35));
}
.nav-brand em { color: var(--amber); font-style: normal; }
.nav-links { display: flex; gap: 26px; list-style: none; }
.nav-links a {
  font-size: 13px; font-weight: 500;
  color: var(--text-muted); text-decoration: none;
  transition: color 0.18s;
}
.nav-links a:hover { color: var(--cream); }
.nav-hire {
  font-size: 12px; font-weight: 700;
  color: var(--ink); background: var(--amber);
  padding: 8px 18px; border-radius: 8px;
  text-decoration: none; letter-spacing: 0.1px;
  transition: opacity 0.18s;
}
.nav-hire:hover { opacity: 0.85; }

/* HERO */
.hero {
  min-height: calc(100vh - 60px);
  display: grid;
  grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
  gap: 28px;
  align-items: center;
  padding: 56px 48px 44px;
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(115deg, rgba(232,150,58,0.10), transparent 34%),
    radial-gradient(circle at 78% 18%, rgba(34,197,94,0.12), transparent 34%),
    var(--ink);
}
.hero::after {
  content: '';
  position: absolute;
  inset: auto 0 0 0;
  height: 1px;
  background: var(--border);
}
.hero-glow-tl { display: none; }
.hero-left {
  display: flex; flex-direction: column; justify-content: center;
  padding: 0;
  position: relative; z-index: 2;
  max-width: 680px;
}
.hero-kicker {
  display: inline-flex; align-items: center; gap: 8px;
  width: max-content;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--amber);
  letter-spacing: 1.5px; text-transform: uppercase;
  border: 1px solid var(--amber-border);
  background: var(--amber-glow);
  padding: 7px 11px; border-radius: 999px;
  margin-bottom: 20px;
}
.hero-status-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--green);
  animation: blink 2.4s ease-in-out infinite;
}
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
.hero-name {
  font-family: 'Sora', sans-serif;
  font-weight: 800;
  font-size: clamp(40px, 4.8vw, 62px);
  line-height: 1.03;
  letter-spacing: -1.8px;
  color: var(--cream);
  max-width: 680px;
  margin-bottom: 22px;
}
.hero-name .accent { color: var(--amber); }
.hero-role-row {
  display: flex; align-items: center; gap: 8px;
  margin: 0 0 24px;
  flex-wrap: wrap;
}
.hero-role-pill {
  font-size: 12px; font-weight: 700;
  color: var(--cream);
  background: rgba(255,255,255,0.045);
  border: 1px solid var(--border-light);
  padding: 8px 12px; border-radius: 8px;
  letter-spacing: 0.1px;
}
.hero-bio {
  font-size: 16px; color: var(--text);
  line-height: 1.75; max-width: 620px;
  margin-bottom: 24px;
}
.hero-bio strong { color: var(--cream); font-weight: 700; }
.hero-btns { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px; }
.btn-solid {
  display: inline-flex; align-items: center; gap: 7px;
  background: var(--amber); color: var(--ink);
  font-weight: 800; font-size: 13px; letter-spacing: 0.1px;
  padding: 13px 24px; border-radius: 9px;
  text-decoration: none; transition: opacity 0.18s, transform 0.18s;
}
.btn-solid:hover { opacity: 0.9; transform: translateY(-1px); }
.btn-outline {
  display: inline-flex; align-items: center; gap: 7px;
  color: var(--cream); font-size: 13px; font-weight: 700;
  border: 1px solid var(--border-light);
  background: rgba(255,255,255,0.035);
  padding: 13px 24px; border-radius: 9px;
  text-decoration: none; transition: all 0.18s;
}
.btn-outline:hover { border-color: var(--amber-border); color: var(--amber); }
.hero-stats {
  display: grid; grid-template-columns: repeat(4, minmax(98px, 1fr)); gap: 10px;
  max-width: 620px;
}
.hero-stat-card {
  border: 1px solid var(--border);
  background: rgba(19,20,28,0.74);
  border-radius: 12px;
  padding: 14px 14px 13px;
}
.hstat-val {
  font-family: 'Sora', sans-serif;
  font-size: 27px; font-weight: 800; letter-spacing: -0.5px;
  color: var(--cream); line-height: 1;
}
.hstat-val em { color: var(--amber); font-style: normal; }
.hstat-lbl {
  font-size: 10px; color: var(--text-muted); margin-top: 7px;
  line-height: 1.35;
}
.hero-right {
  position: relative;
  min-height: 560px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border);
  border-radius: 22px;
  overflow: hidden;
  background: linear-gradient(160deg, rgba(19,21,32,0.92) 0%, rgba(12,13,20,0.98) 100%);
}
.hero-right::before {
  content: '';
  position: absolute; inset: 34px;
  border: 1px solid rgba(255,255,255,0.05);
  border-radius: 18px;
  pointer-events: none;
}
.hero-app-label {
  position: absolute; top: 24px; left: 24px; right: 24px;
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--text-muted);
  letter-spacing: 0.7px; text-transform: uppercase;
  white-space: nowrap;
  z-index: 3;
}
.hero-app-label span { color: var(--amber); }
.hero-app-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); opacity: 0.8; }
.hero-phone-wrap {
  position: relative;
  width: min(72%, 320px);
  margin-top: 38px;
  filter: drop-shadow(0 36px 80px rgba(0,0,0,0.78));
  z-index: 2;
}
.hero-phone-wrap img {
  width: 100%;
  display: block;
}
.hero-product-card {
  position: absolute;
  left: 22px; bottom: 24px;
  max-width: 245px;
  background: rgba(9,9,14,0.78);
  border: 1px solid var(--amber-border);
  backdrop-filter: blur(14px);
  border-radius: 14px;
  padding: 14px 15px;
  z-index: 4;
}
.hero-product-card strong {
  display: block; color: var(--cream);
  font-size: 13px; font-weight: 800;
  margin-bottom: 4px;
}
.hero-product-card span {
  display: block;
  font-size: 11px; color: var(--text-muted);
  line-height: 1.45;
}
/* SCROLL TICKER */
.ticker {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 14px 0; overflow: hidden; position: relative;
}
.ticker::before, .ticker::after {
  content: ''; position: absolute; top: 0; bottom: 0; width: 80px;
  z-index: 2; pointer-events: none;
}
.ticker::before { left: 0; background: linear-gradient(to right, var(--ink), transparent); }
.ticker::after  { right: 0; background: linear-gradient(to left, var(--ink), transparent); }
.ticker-track {
  display: flex; gap: 0;
  width: max-content;
  animation: ticker-scroll 32s linear infinite;
}
@keyframes ticker-scroll { from{transform:translateX(0)} to{transform:translateX(-50%)} }
.ticker-item {
  display: flex; align-items: center; gap: 8px;
  padding: 0 28px; white-space: nowrap;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: var(--text-faint);
  border-right: 1px solid var(--border);
  letter-spacing: 0.2px;
}
.ticker-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--amber); opacity: 0.5; flex-shrink: 0; }

/* SECTION BASICS */
section { padding: 88px 48px; }
.container { max-width: 1040px; margin: 0 auto; }
.eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--amber);
  letter-spacing: 2.5px; text-transform: uppercase; margin-bottom: 10px;
}
.sec-h {
  font-family: 'Sora', sans-serif;
  font-size: clamp(28px, 3.5vw, 44px); font-weight: 700;
  color: var(--cream); letter-spacing: -1.2px; line-height: 1.05;
  margin-bottom: 10px;
}
.sec-sub { font-size: 15px; color: var(--text-muted); max-width: 460px; line-height: 1.75; margin-bottom: 52px; }

/* SERVICES */
.services-section { background: var(--ink); }
.svc-grid {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--border);
  border: 1px solid var(--border); border-radius: var(--rx); overflow: hidden;
}
.svc-grid-b { grid-template-columns: repeat(3, 1fr); margin-top: 2px; }
.svc-card {
  background: var(--ink2); padding: 30px 26px;
  transition: background 0.18s; position: relative;
}
.svc-card:hover { background: var(--ink3); }
.svc-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--text-faint); margin-bottom: 16px;
}
.svc-card h3 {
  font-family: 'Sora', sans-serif;
  font-size: 16px; font-weight: 700; color: var(--cream);
  margin-bottom: 9px; letter-spacing: -0.3px; line-height: 1.2;
}
.svc-card p { font-size: 13px; color: var(--text-muted); line-height: 1.7; margin-bottom: 18px; }
.svc-tags { display: flex; flex-wrap: wrap; gap: 5px; }
.svc-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--text-faint);
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border); padding: 3px 9px; border-radius: 4px;
}
.svc-card.hot { border-top: 2px solid var(--amber); }
.svc-hot-badge {
  position: absolute; top: 0; right: 0;
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; font-weight: 700; color: var(--amber);
  background: var(--amber-glow); padding: 5px 11px;
  border-bottom-left-radius: 8px; letter-spacing: 0.5px;
}

/* PROJECTS */
.projects-section { background: var(--ink2); }
.proj-list { display: flex; flex-direction: column; gap: 2px; }
.proj-card {
  background: var(--ink2); border: 1px solid var(--border);
  border-radius: var(--r); padding: 26px 30px;
  display: grid; grid-template-columns: 1fr auto; gap: 20px; align-items: start;
  transition: border-color 0.18s, background 0.18s;
}
.proj-card:hover { border-color: var(--amber-border); background: rgba(232,150,58,0.025); }
.proj-cat {
  font-family: 'JetBrains Mono', monospace;
  font-size: 10px; color: var(--amber);
  letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 7px;
}
.proj-name {
  font-family: 'Sora', sans-serif;
  font-size: 17px; font-weight: 700; color: var(--cream);
  letter-spacing: -0.3px; margin-bottom: 9px;
}
.proj-desc { font-size: 13px; color: var(--text-muted); line-height: 1.75; max-width: 580px; margin-bottom: 14px; }
.proj-stack { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px; }
.proj-tag {
  font-family: 'JetBrains Mono', monospace; font-size: 10px;
  color: var(--text-faint); background: rgba(255,255,255,0.04);
  border: 1px solid var(--border); padding: 3px 9px; border-radius: 4px;
}
.proj-live {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--text-faint);
}
.proj-live::before {
  content: ''; width: 6px; height: 6px; border-radius: 50%;
  background: var(--green); flex-shrink: 0;
  animation: blink 2s ease-in-out infinite;
}
.proj-metric { text-align: right; padding-top: 4px; }
.proj-metric-val {
  font-family: 'Sora', sans-serif;
  font-size: 22px; font-weight: 700; color: var(--amber);
  letter-spacing: -0.5px; line-height: 1;
}
.proj-metric-lbl { font-size: 11px; color: var(--text-muted); margin-top: 4px; line-height: 1.35; }

/* EXPERIENCE */
.exp-section { background: var(--ink); }
.exp-list { display: flex; flex-direction: column; }
.exp-row {
  display: grid; grid-template-columns: 150px 1fr;
  gap: 0 30px; padding: 30px 0;
  border-bottom: 1px solid var(--border); position: relative;
}
.exp-row:last-child { border-bottom: none; }
.exp-row::before {
  content: ''; position: absolute;
  left: 138px; top: 0; bottom: 0; width: 1px;
  background: var(--border);
}
.exp-date {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: var(--text-faint); line-height: 1.4; padding-top: 4px;
}
.exp-now { display: block; margin-top: 6px; font-size: 10px; color: var(--amber); letter-spacing: 0.3px; }
.exp-role {
  font-family: 'Sora', sans-serif;
  font-size: 16px; font-weight: 700; color: var(--cream); letter-spacing: -0.3px; margin-bottom: 2px;
}
.exp-co { font-size: 13px; color: var(--amber); font-weight: 600; margin-bottom: 10px; }
.exp-ul { list-style: none; display: flex; flex-direction: column; gap: 4px; }
.exp-ul li {
  font-size: 13px; color: var(--text-muted);
  padding-left: 15px; position: relative; line-height: 1.65;
}
.exp-ul li::before {
  content: ''; position: absolute; left: 0; top: 9px;
  width: 5px; height: 1px; background: var(--text-faint);
}

/* SKILLS */
.skills-section { background: var(--ink2); }
.skills-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }
.skgrp { margin-bottom: 32px; }
.skgrp:last-child { margin-bottom: 0; }
.skgrp-label {
  font-family: 'Sora', sans-serif;
  font-size: 13px; font-weight: 700; color: var(--cream);
  margin-bottom: 12px; padding-bottom: 10px;
  border-bottom: 1px solid var(--border);
}
.sk-row { display: flex; align-items: center; gap: 10px; padding: 5px 0; }
.sk-name { font-size: 12px; color: var(--text-muted); width: 155px; flex-shrink: 0; }
.sk-track { flex: 1; height: 3px; background: rgba(255,255,255,0.05); border-radius: 2px; overflow: hidden; }
.sk-fill { height: 100%; border-radius: 2px; background: var(--amber); opacity: 0.65; }
.sk-yr { font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text-faint); width: 24px; text-align: right; flex-shrink: 0; }

/* CERTS */
.certs-section { background: var(--ink2); }
.certs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 10px; }
.cert-card {
  background: var(--ink3); border: 1px solid var(--border);
  border-radius: var(--r); padding: 18px 20px;
  display: flex; align-items: flex-start; gap: 13px;
  transition: border-color 0.18s;
}
.cert-card:hover { border-color: var(--amber-border); }
.cert-badge {
  width: 36px; height: 36px; flex-shrink: 0; border-radius: 8px;
  background: var(--amber-glow); border: 1px solid var(--amber-border);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Sora', sans-serif; font-size: 10px; font-weight: 800; color: var(--amber);
}
.cert-name { font-size: 13px; font-weight: 600; color: var(--cream); line-height: 1.3; margin-bottom: 3px; }
.cert-issuer { font-size: 12px; color: var(--text-muted); margin-bottom: 5px; }
.cert-pill {
  font-size: 9px; font-weight: 700; padding: 2px 8px; border-radius: 100px;
  display: inline-block; letter-spacing: 0.4px;
}
.cert-pill.active { background: rgba(34,197,94,0.1); color: #4ADE80; border: 1px solid rgba(34,197,94,0.22); }
.cert-pill.progress { background: var(--amber-glow); color: var(--amber); border: 1px solid var(--amber-border); }
.cert-pill.verify { background: rgba(99,179,237,0.1); color: #90CDF4; border: 1px solid rgba(99,179,237,0.22); }

/* WHY WORK WITH ME */
.why-section { background: var(--ink); }
.why-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 12px; }
.why-card {
  background: var(--ink2); border: 1px solid var(--border);
  border-radius: var(--r); padding: 20px 22px;
  display: flex; gap: 14px; align-items: flex-start;
  transition: border-color 0.18s;
}
.why-card:hover { border-color: var(--amber-border); }
.why-icon {
  width: 28px; height: 28px; border-radius: 7px; flex-shrink: 0;
  background: var(--amber-glow); border: 1px solid var(--amber-border);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; margin-top: 1px;
}
.why-card h4 { font-size: 14px; font-weight: 700; color: var(--cream); margin-bottom: 5px; letter-spacing: -0.2px; }
.why-card p { font-size: 13px; color: var(--text-muted); line-height: 1.65; }

/* CONTACT */
.contact-section { background: var(--ink2); border-top: 1px solid var(--border); }
.contact-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 72px; align-items: start; }
.contact-left .sec-sub { max-width: 100%; }
.c-links { display: flex; flex-direction: column; gap: 8px; }
.c-link {
  display: flex; align-items: center; gap: 12px;
  padding: 13px 16px; background: var(--ink3);
  border: 1px solid var(--border); border-radius: var(--r);
  text-decoration: none; transition: border-color 0.18s, background 0.18s;
}
.c-link:hover { border-color: var(--amber-border); background: var(--amber-glow); }
.c-ico {
  width: 30px; height: 30px; border-radius: 7px; flex-shrink: 0;
  background: var(--amber-glow); border: 1px solid var(--amber-border);
  display: flex; align-items: center; justify-content: center;
}
.c-ico svg { width: 14px; height: 14px; stroke: var(--amber); fill: none; stroke-width: 2; }
.c-lbl { display: block; font-family: 'JetBrains Mono', monospace; font-size: 9px; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.8px; }
.c-val { display: block; font-size: 13px; font-weight: 600; color: var(--cream); margin-top: 1px; }
.avail-card {
  background: var(--ink3); border: 1px solid var(--amber-border);
  border-radius: var(--rl); padding: 28px;
}
.avail-card h3 {
  font-family: 'Sora', sans-serif;
  font-size: 17px; font-weight: 700; color: var(--cream);
  letter-spacing: -0.3px; margin-bottom: 7px;
}
.avail-card p { font-size: 13px; color: var(--text-muted); line-height: 1.7; margin-bottom: 20px; }
.avail-list { display: flex; flex-direction: column; gap: 7px; }
.avail-row {
  display: flex; align-items: center; gap: 9px;
  font-size: 13px; color: var(--text-muted);
}
.avail-tick {
  width: 17px; height: 17px; border-radius: 4px; flex-shrink: 0;
  background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 9px; color: #4ADE80; font-weight: 700;
}

/* FOOTER */
footer {
  border-top: 1px solid var(--border);
  padding: 22px 48px;
  display: flex; align-items: center; justify-content: space-between;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: var(--text-faint);
}
footer a { color: var(--text-faint); text-decoration: none; }
footer a:hover { color: var(--amber); }

/* RESPONSIVE */
@media (max-width: 900px) {
  .hero { grid-template-columns: 1fr; padding: 56px 24px; min-height: auto; }
  .hero-name { font-size: clamp(38px, 10vw, 54px); }
  .hero-stats { grid-template-columns: repeat(2, 1fr); }
  .hero-right { min-height: 520px; border-radius: 16px; }
  .hero-phone-wrap { width: min(82%, 280px); }
  .hero-product-card { left: 16px; right: 16px; bottom: 16px; max-width: none; }
  nav { padding: 0 24px; }
  .nav-links { display: none; }
  section { padding: 60px 24px; }
  .svc-grid, .svc-grid-b { grid-template-columns: 1fr; }
